---
import Layout from "../../layouts/Layout.astro";
import { fetchNews, fetchNewsBySlug } from "../../lib/strapi";

export async function getStaticPaths() {
  const news = await fetchNews();
  return news.map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await fetchNewsBySlug(slug!);

if (!article) {
  return Astro.redirect("/nyheter");
}

const formattedDate = new Date(article.date).toLocaleDateString("nb-NO", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<Layout title={article.title} description={article.excerpt}>
  <article>
    <header class="bg-gradient-to-br from-dark via-dark-light to-primary-900 py-20 sm:py-28">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <a
          href="/nyheter"
          class="inline-flex items-center gap-1 text-sm text-gray-400 transition-colors hover:text-white"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Tilbake til nyheter
        </a>
        <time datetime={article.date} class="mt-6 block text-sm font-medium text-primary-400 uppercase tracking-wide">
          {formattedDate}
        </time>
        <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {article.title}
        </h1>
      </div>
    </header>

    {article.image && (
      <div class="mx-auto -mt-8 max-w-4xl px-4 sm:px-6 lg:px-8">
        <img
          src={article.image}
          alt={article.title}
          class="w-full rounded-2xl shadow-xl"
          loading="eager"
        />
      </div>
    )}

    <div class="py-12 sm:py-16">
      <div class="prose prose-lg mx-auto max-w-4xl px-4 sm:px-6 lg:px-8" set:html={article.content} />
    </div>
  </article>
</Layout>
