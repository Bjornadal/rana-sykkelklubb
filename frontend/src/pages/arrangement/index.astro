---
import { url } from "../../lib/url";

/** Liste over arrangement ligger nå under Aktiviteter (#arrangement). */
const target = `${url("/aktiviteter")}#arrangement`;
---
<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <title>Omdirigerer …</title>
  </head>
  <body>
    <p><a href={target}>Gå til aktiviteter og arrangement</a></p>
    <script is:inline define:vars={{ target }}>
      location.replace(target);
    </script>
  </body>
</html>
