---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

const boardContacts = [
  { name: "Bjørn Einar Nesengmo", role: "Leder", phone: "+47 952 08 129" },
  { name: "Tomek Pietrzykowski", role: "Nestleder", phone: "+47 486 86 426" },
  { name: "Katrine Stormdalshei", role: "Kasserer", phone: "+47 481 51 531" },
  { name: "Andreas Bjørnådal", role: "Styremedlem", phone: "+47 994 47 744" },
  { name: "Simon Fossheim", role: "Styremedlem", phone: "+47 907 33 241" },
  { name: "Kjell Martinsen", role: "Styremedlem" },
];

const materialManagers = ["Jan Magne Hansen", "Dag Ove Olsen"];
---

<Layout title="Kontakt" description="Ta kontakt med Rana Sykkelklubb.">
  <PageHeader
    title="Kontakt oss"
    description="Vi hører gjerne fra deg – enten du har spørsmål om medlemskap, aktiviteter eller annet."
  />

  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-3">
        <!-- Kontaktinfo -->
        <div class="lg:col-span-1">
          <div class="space-y-8">
            <div class="rounded-2xl bg-primary-600 p-8 text-white">
              <h2 class="text-xl font-bold">Kontaktinformasjon</h2>
              <div class="mt-6 space-y-4">
                <div class="flex items-start gap-3">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <div>
                    <p class="text-sm text-primary-200">E-post</p>
                    <a href="mailto:post@ranasykkelklubb.no" class="font-medium hover:text-primary-100">
                      post@ranasykkelklubb.no
                    </a>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <div>
                    <p class="text-sm text-primary-200">Postadresse</p>
                    <p class="font-medium">Hammerveien 75B</p>
                    <p class="font-medium">8626 Mo i Rana</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                  <div>
                    <p class="text-sm text-primary-200">Org.nr</p>
                    <p class="font-medium">986 842 306</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="rounded-2xl bg-gray-50 p-8">
              <h3 class="font-bold text-dark">Materialforvaltere</h3>
              <ul class="mt-4 space-y-2 text-sm text-gray-600">
                {materialManagers.map((name) => (
                  <li class="flex items-center gap-2">
                    <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    {name}
                  </li>
                ))}
              </ul>
            </div>

            <div class="rounded-2xl bg-[#1877F2] p-8 text-white">
              <h3 class="text-xl font-bold">Følg oss på Facebook</h3>
              <p class="mt-2 text-sm text-blue-100">Hold deg oppdatert via våre Facebook-sider.</p>
              <ul class="mt-5 space-y-3">
                <li>
                  <a href="https://www.facebook.com/profile.php?id=61583644916540" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-lg bg-white/15 px-4 py-3 font-medium transition-colors hover:bg-white/25">
                    <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    Rana Bike Park
                  </a>
                </li>
                <li>
                  <a href="https://www.facebook.com/groups/170941269606870/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-lg bg-white/15 px-4 py-3 font-medium transition-colors hover:bg-white/25">
                    <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    Rana Sykkelklubb
                  </a>
                </li>
                <li>
                  <a href="https://www.facebook.com/groups/1205541267871593/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-lg bg-white/15 px-4 py-3 font-medium transition-colors hover:bg-white/25">
                    <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    Rana Sykkelklubb Terreng
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Styrets kontaktinfo -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-dark">Styret</h2>
          <p class="mt-2 text-gray-600">Kontaktinformasjon for styrets medlemmer.</p>

          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {boardContacts.map((member) => (
              <div class="flex items-start gap-4 rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary-100 text-primary-700">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-dark">{member.name}</p>
                  <p class="text-sm text-gray-500">{member.role}</p>
                  {member.phone && (
                    <a href={`tel:${member.phone.replace(/\s/g, "")}`} class="mt-1 inline-flex items-center gap-1 text-sm text-primary-600 hover:text-primary-700">
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                      </svg>
                      {member.phone}
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
