---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import DisciplineCard from "../components/DisciplineCard.astro";
import NewsCard from "../components/NewsCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { url } from "../lib/url";

const disciplines = [
  {
    title: "Landevei",
    description:
      "Fellestreninger, turritt og satsing mot nasjonale mesterskap. For deg som elsker farten og asfalten.",
    icon: "🚴",
    color: "bg-blue-100 text-blue-600",
  },
  {
    title: "Terrengsykling (MTB)",
    description:
      "Stisykling og terrengritt i fantastisk natur på Helgeland. Teknikk, spenning og naturopplevelser.",
    icon: "🏔️",
    color: "bg-green-100 text-green-600",
  },
  {
    title: "E-MTB",
    description:
      "Elektrisk terrengsykling for alle nivåer. En perfekt måte å utforske naturen med litt ekstra hjelp.",
    icon: "⚡",
    color: "bg-yellow-100 text-yellow-600",
  },
  {
    title: "Enduro",
    description:
      "Tekniske stier og fartsfylte utforkjøringer. For deg som søker utfordringer og adrenalinkick.",
    icon: "🔥",
    color: "bg-red-100 text-red-600",
  },
];

const latestNews = [
  {
    title: "Årsmøtet må utsettes!",
    excerpt:
      "Valgkomiteen har fått en ekstra utfordring med ledervervet i klubben. Det betyr at vi må gi valgkomiteen ekstra tid til å løse denne utfordringen.",
    date: "2026-03-10",
    slug: "arsmotet-ma-utsettes",
  },
  {
    title: "Årsmøte for sesong 2024 avviklet",
    excerpt: "Referat fra årsmøtet finner du under Om klubben.",
    date: "2025-04-27",
    slug: "arsmote-sesong-2024",
  },
  {
    title: "Terrengsykkelgruppe etablert",
    excerpt:
      "26. juni ble det vedtatt at klubben skal opprette en egen gruppe for terreng- og stisykling.",
    date: "2024-06-29",
    slug: "terrengsykkelgruppe-etablert",
  },
];
---

<Layout title="Forside">
  <Hero
    title="Sykkelglede for alle på Helgeland"
    subtitle="Rana Sykkelklubb har fremmet sykkelsporten i Rana siden 1983. Vi tilbyr et bredt og aktivt sykkelmiljø for barn, ungdom og voksne – på asfalt, grus og sti."
    cta={{ label: "Bli medlem", href: "/medlemskap" }}
    ctaSecondary={{ label: "Se aktiviteter", href: "/aktiviteter" }}
  />

  <!-- Disipliner -->
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Våre disipliner"
        subtitle="Enten du foretrekker glatt asfalt eller tekniske stier – vi har noe for deg."
      />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {disciplines.map((d) => (
          <DisciplineCard
            title={d.title}
            description={d.description}
            icon={d.icon}
            color={d.color}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Sykkelpark -->
  <section class="bg-gray-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <span class="inline-block rounded-full bg-primary-100 px-4 py-1 text-sm font-semibold text-primary-700">
            Nytt prosjekt
          </span>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-dark sm:text-4xl">
            Rana Sykkelpark – Fremtidens møteplass
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-gray-600">
            Vi jobber for å skape en inkluderende sykkelpark med pumptrack, hoppanlegg og
            flytstier. Parken skal gi glede, mestring og aktivitet for barn, ungdom og voksne.
          </p>
          <ul class="mt-8 space-y-3">
            {["Pumptrack for alle nivåer", "Hoppanlegg med ulike vanskelighetsgrader", "Flytstier i naturskjønne omgivelser", "Bygges trinnvis etter finansiering"].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">{item}</span>
              </li>
            ))}
          </ul>
          <a
            href={url("/sykkelpark")}
            class="mt-8 inline-flex items-center rounded-lg bg-primary-600 px-6 py-3 text-base font-semibold text-white shadow transition-all hover:bg-primary-500"
          >
            Les mer om Rana Bike Park
          </a>
        </div>
        <div class="relative">
          <a href={url("/rana-bike-park-map.jpg")} target="_blank" rel="noopener noreferrer" class="group block overflow-hidden rounded-2xl shadow-lg transition-shadow hover:shadow-xl">
            <img
              src={url("/rana-bike-park-map.jpg")}
              alt="Illustrasjon av Rana Bike Park – oversiktskart over anlegget i Munklia og Båsmofjellet"
              class="h-auto w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
              loading="lazy"
            />
            <span class="absolute bottom-3 right-3 flex items-center gap-1.5 rounded-lg bg-black/60 px-3 py-1.5 text-xs font-medium text-white opacity-0 backdrop-blur-sm transition-opacity group-hover:opacity-100">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
              </svg>
              Vis fullstørrelse
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Nyheter -->
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        title="Siste nyheter"
        subtitle="Hold deg oppdatert på hva som skjer i klubben."
      />
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {latestNews.map((news) => (
          <NewsCard
            title={news.title}
            excerpt={news.excerpt}
            date={news.date}
            slug={news.slug}
          />
        ))}
      </div>
      <div class="mt-12 text-center">
        <a
          href={url("/nyheter")}
          class="inline-flex items-center rounded-lg border border-gray-300 px-6 py-3 text-base font-semibold text-dark transition-all hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700"
        >
          Se alle nyheter
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary-600">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Bli en del av sykkelmiljøet i Rana
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
          Uansett om du er nybegynner eller erfaren – det er plass til deg hos oss.
          Medlemskapet gir deg tilgang til treninger, rabatter og et flott fellesskap.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href={url("/medlemskap")}
            class="inline-flex items-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-primary-700 shadow transition-all hover:bg-gray-50"
          >
            Meld deg inn i dag
          </a>
          <a
            href={url("/kontakt")}
            class="inline-flex items-center rounded-lg border border-primary-300 px-6 py-3 text-base font-semibold text-white transition-all hover:bg-primary-500"
          >
            Ta kontakt
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
