---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { url } from "../lib/url";

const features = [
  {
    title: "Asfaltert pumptrack",
    description:
      "En moderne lekeplass for sykkel, skateboard og sparkesykkel. Passer nybegynnere og erfarne, og kan arrangere lokale og internasjonale konkurranser. Ca. 60–100 m i lengde med flere linjer, pluss en egen mini-bane for de minste.",
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  },
  {
    title: "Ferdighetsområde",
    description:
      "Spesialbygd arena for å utvikle sykkelferdigheter – med balansehindre, små hopp, lave drops og teknikkelementer. Konstrueres i tre, stein og jord nært pumptracken.",
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
  },
  {
    title: "Hopplinjer",
    description:
      "Progressiv hoppelelinjer i åpent terreng – fra nybegynnervennlige tabletops til avanserte gap-hopp. Minst to linjer med tydelig progresjon i størrelse og sikre landingssoner.",
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.306a11.95 11.95 0 015.814-5.518l2.74-1.22m0 0l-5.94-2.281m5.94 2.28l-2.28 5.941" /></svg>`,
  },
  {
    title: "Flytstier",
    description:
      "Grønne, blå, røde og svarte stier i naturlig terreng med doserte svinger og naturlig flyt. Fra familievennlige nybegynnerstier til tekniske utfordringer for erfarne ryttere.",
    icon: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" /></svg>`,
  },
];

const timeline = [
  {
    year: "2025",
    title: "Forprosjekt og masterplan",
    items: [
      "Kartlegging av behov fra skoler, barnehager og brukere",
      "Masterplan utarbeides av Trailhead Nesbyen",
      "Dialog med kommunen om byggesøknad og dispensasjon",
    ],
    status: "pågår",
    statusColor: "bg-primary-100 text-primary-700",
  },
  {
    year: "2026",
    title: "Fase 0: Forberedelser og rydding",
    items: [
      "Reguleringsavklaringer og prosjektering",
      "Miljøundersøkelser",
      "Detaljprosjektering og tekniske kostnadsoverslag",
    ],
    status: "planlagt",
    statusColor: "bg-gray-100 text-gray-600",
  },
  {
    year: "2027",
    title: "Byggetrinn 1: Sosialt",
    items: [
      "Asfaltert pumptrack + mini-bane",
      "Ferdighetsområde (skills area)",
      "Hopplinjer (dirt lines)",
      "Grønne og blå flytstier",
      "Oppholdsplasser og infrastruktur",
    ],
    status: "planlagt",
    statusColor: "bg-gray-100 text-gray-600",
    budget: "~19,6 mill. kr",
    theme: "Lek, mestring og trygg introduksjon til sykling for alle aldre",
  },
  {
    year: "2028",
    title: "Byggetrinn 2: Flyt",
    items: [
      "Blå og røde flytløyper (flow trails)",
      "Air DH / hopplinjer",
      "Oppstigningsstier og utsiktspunkter",
      "Kobling mot eksisterende traseer",
    ],
    status: "planlagt",
    statusColor: "bg-gray-100 text-gray-600",
    budget: "~10,3 mill. kr",
    theme: "Variasjon, progresjon og rom for trening og lokale ritt",
  },
  {
    year: "2029",
    title: "Byggetrinn 3: Fart",
    items: [
      "Røde og svarte tekniske stier",
      "Tekniske seksjoner med steiner, røtter og bratte partier",
      "E-sykkel-vennlige klatreruter",
      "Naturopplevelse og utsiktspunkter",
    ],
    status: "planlagt",
    statusColor: "bg-gray-100 text-gray-600",
    budget: "~29,4 mill. kr",
    theme: "Utfordringer, utvikling og potensial for arrangementer",
  },
  {
    year: "2030+",
    title: "Videre utvikling",
    items: [
      "Utvidelse av stinettverk",
      "Arrangementstilpasset infrastruktur",
      "Digitale verktøy og apper for brukerinformasjon",
    ],
    status: "fremtidig",
    statusColor: "bg-gray-100 text-gray-600",
  },
];

const targetGroups = [
  { group: "Barn og unge (4–18 år)", description: "Lek, trygg ferdighetstrening og progresjon" },
  { group: "Familier", description: "Delte opplevelser og trygg plass for læring og bevegelse" },
  { group: "Skoler og barnehager", description: "Kroppsøving, ferdighetstrening og sykkelopplæring" },
  { group: "Mosjonister og voksne", description: "Trening, naturopplevelser og mestring" },
  { group: "Reiseliv og tilreisende", description: "Aktivitet for bobilturister, campinggjester og sykkelturister" },
  { group: "Idrettslag og klubber", description: "Rekruttering, trening og konkurranseområde" },
];
---

<Layout title="Rana Bike Park" description="Rana Bike Park – Nord-Norges mest inkluderende sykkelpark med pumptrack, hoppanlegg og flytstier i Munklia og Båsmofjellet.">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-dark">
    <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark/80 to-primary-900/50"></div>
    <div class="relative mx-auto max-w-7xl px-4 py-28 sm:px-6 sm:py-36 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block rounded-full bg-primary-500/20 px-4 py-1 text-sm font-semibold text-primary-400 ring-1 ring-primary-500/30">
          Munklia &middot; Båsmofjellet &middot; Skillevollen
        </span>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Rana Bike Park
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-gray-300 sm:text-xl">
          Et helhetlig anlegg for terrengsykling og aktivitet i Mo i Rana. Visjonen er å utvikle
          Nord-Norges mest inkluderende, tilgjengelige og bærekraftige sykkelpark – en helårsarena
          for mestring, lek og naturopplevelse.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href={url("/kontakt")}
            class="inline-flex items-center rounded-lg bg-primary-500 px-6 py-3 text-base font-semibold text-white shadow-lg transition-all hover:bg-primary-400 hover:shadow-xl"
          >
            Ta kontakt
          </a>
          <a
            href={url("/medlemskap")}
            class="inline-flex items-center rounded-lg border border-gray-500 px-6 py-3 text-base font-semibold text-white transition-all hover:border-white hover:bg-white/10"
          >
            Støtt prosjektet – bli medlem
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 60V30C360 0 720 0 1080 30C1260 45 1350 52.5 1440 60H0Z" fill="white" />
      </svg>
    </div>
  </section>

  <!-- Visjonen -->
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-16 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl">
            Visjonen
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-gray-600">
            Rana Bike Park er svaret på hvordan vi kan styrke Mo i Ranas posisjon som
            sykkeldestinasjon. Et sted der idrett, friluftsliv og fellesskap møtes, og der sykling
            blir en naturlig del av både hverdagsliv og reiseliv.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-gray-600">
            Parken planlegges i Munklia og Båsmofjellet, med direkte tilknytning til Skillevollen.
            Området har et kupert landskap med naturlige høydeforskjeller, skogkledde skråninger
            og gode forutsetninger for sykkelanlegg med relativt små inngrep.
          </p>
          <div class="mt-8 grid grid-cols-3 gap-6">
            <div class="text-center">
              <span class="text-3xl font-extrabold text-primary-600">~59</span>
              <p class="mt-1 text-sm text-gray-500">Mill. kr totalt</p>
            </div>
            <div class="text-center">
              <span class="text-3xl font-extrabold text-primary-600">3</span>
              <p class="mt-1 text-sm text-gray-500">Byggetrinn</p>
            </div>
            <div class="text-center">
              <span class="text-3xl font-extrabold text-primary-600">800+</span>
              <p class="mt-1 text-sm text-gray-500">Barn i nærområdet</p>
            </div>
          </div>
        </div>
        <div class="relative">
          <a href={url("/rana-bike-park-map.jpg")} target="_blank" rel="noopener noreferrer" class="group block overflow-hidden rounded-2xl shadow-lg transition-shadow hover:shadow-xl">
            <img
              src={url("/rana-bike-park-map.jpg")}
              alt="Illustrasjon av Rana Bike Park – oversiktskart over anlegget i Munklia og Båsmofjellet"
              class="h-auto w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
              loading="lazy"
            />
            <span class="absolute bottom-3 right-3 flex items-center gap-1.5 rounded-lg bg-black/60 px-3 py-1.5 text-xs font-medium text-white opacity-0 backdrop-blur-sm transition-opacity group-hover:opacity-100">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
              </svg>
              Vis fullstørrelse
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Anlegg -->
  <section class="bg-gray-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl">Hva kommer i parken?</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          Et komplett sykkelanlegg med pumptrack, ferdighetsløyper, flytstier, hoppelinjer og
          tekniske stier – tilpasset alle nivåer og aldersgrupper.
        </p>
      </div>
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {features.map((feature) => (
          <div class="rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-100 transition-all hover:-translate-y-1 hover:shadow-lg">
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary-100 text-primary-600">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="mt-5 text-lg font-bold text-dark">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Målgrupper -->
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl">For hvem?</h2>
      <p class="mt-4 max-w-2xl text-lg text-gray-600">
        Rana Bike Park er designet for bred bruk og høy tilgjengelighet. Gratis og åpen for alle.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {targetGroups.map((item) => (
          <div class="flex items-start gap-4 rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-100 text-primary-600">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-dark">{item.group}</p>
              <p class="mt-1 text-sm text-gray-500">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Utbyggingsplan / Tidslinje -->
  <section class="bg-gray-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl">Utbyggingsplan</h2>
      <p class="mt-4 max-w-3xl text-lg text-gray-600">
        Parken bygges trinnvis. Hver fase står sterkt alene og gir umiddelbar verdi for brukere
        og lokalmiljø, samtidig som den gradvis bygger opp parkens fulle tilbud.
      </p>

      <div class="relative mt-12">
        <div class="absolute left-[2.3rem] top-0 hidden h-full w-0.5 bg-gray-200 sm:block" aria-hidden="true"></div>
        <div class="space-y-8">
          {timeline.map((item) => (
            <div class="relative flex gap-6">
              <div class="hidden shrink-0 sm:flex">
                <div class="relative z-10 flex h-[3.1rem] w-[3.1rem] items-center justify-center rounded-full bg-white text-xs font-extrabold text-primary-700 ring-4 ring-white shadow-sm">
                  {item.year}
                </div>
              </div>
              <div class="flex-1 rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-100 sm:p-8">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="text-sm font-bold text-primary-600 sm:hidden">{item.year}</span>
                  <h3 class="text-lg font-bold text-dark">{item.title}</h3>
                  <span class:list={["rounded-full px-3 py-0.5 text-xs font-medium capitalize", item.statusColor]}>
                    {item.status}
                  </span>
                </div>
                {item.theme && (
                  <p class="mt-2 text-sm italic text-gray-500">{item.theme}</p>
                )}
                <ul class="mt-4 space-y-2">
                  {item.items.map((li) => (
                    <li class="flex items-start gap-2">
                      <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-sm text-gray-700">{li}</span>
                    </li>
                  ))}
                </ul>
                {item.budget && (
                  <div class="mt-4 inline-flex items-center gap-2 rounded-lg bg-gray-50 px-3 py-1.5 text-sm font-medium text-gray-700">
                    <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Budsjett: {item.budget}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Samarbeid -->
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl">Organisering og samarbeid</h2>
          <p class="mt-4 text-lg text-gray-600">
            Prosjektet er forankret i lokalt engasjement, fagkompetanse og solide samarbeidspartnere.
          </p>
          <dl class="mt-8 space-y-6">
            <div>
              <dt class="font-semibold text-dark">Prosjekteier</dt>
              <dd class="mt-1 text-gray-600">Rana Sykkelklubb – ansvarlig for planlegging, utvikling, drift og koordinering.</dd>
            </div>
            <div>
              <dt class="font-semibold text-dark">Masterplan og stibygging</dt>
              <dd class="mt-1 text-gray-600">Trailhead Nesbyen – faglig rådgivning med dokumentert erfaring fra sykkelanlegg over hele Norge.</dd>
            </div>
            <div>
              <dt class="font-semibold text-dark">Samarbeid</dt>
              <dd class="mt-1 text-gray-600">Bossmo & Ytteren IL drifter området Skillevollen. Prosjektet er utviklet i tett dialog med Rana kommune, skoler, barnehager og lokale friluftsaktører.</dd>
            </div>
          </dl>
        </div>
        <div class="flex flex-col justify-center">
          <blockquote class="rounded-2xl bg-gray-50 p-8">
            <p class="text-lg italic leading-relaxed text-gray-700">
              &laquo;Visit Helgeland ser med spenning på og gir sin fulle støtte til etableringen
              av Rana Bike Park i Mo i Rana. Vi ser frem til å bruke Rana Bike Park aktivt i
              produktutvikling og i vår markedsføring.&raquo;
            </p>
            <footer class="mt-4">
              <p class="font-semibold text-dark">Kitt Grønningsæter</p>
              <p class="text-sm text-gray-500">Daglig leder/reiselivssjef, Visit Helgeland AS</p>
            </footer>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Støtt prosjektet -->
  <section class="bg-primary-600">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Støtt Rana Bike Park
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
          Ved å bli medlem i Rana Sykkelklubb støtter du arbeidet med å realisere sykkelparken.
          Sammen bygger vi fremtidens møteplass for sykkelglede – for hele Helgeland.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href={url("/medlemskap")}
            class="inline-flex items-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-primary-700 shadow transition-all hover:bg-gray-50"
          >
            Bli medlem
          </a>
          <a
            href={url("/kontakt")}
            class="inline-flex items-center rounded-lg border border-primary-300 px-6 py-3 text-base font-semibold text-white transition-all hover:bg-primary-500"
          >
            Kontakt oss
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
