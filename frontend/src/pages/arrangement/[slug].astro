---
import Layout from "../../layouts/Layout.astro";
import { fetchEvents, fetchEventBySlug } from "../../lib/strapi";

export async function getStaticPaths() {
  const events = await fetchEvents();
  return events.map((event) => ({
    params: { slug: event.slug },
  }));
}

const { slug } = Astro.params;
const event = await fetchEventBySlug(slug!);

if (!event) {
  return Astro.redirect("/arrangement");
}

const formattedDate = event.date
  ? new Date(event.date).toLocaleDateString("nb-NO", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : null;
---

<Layout title={event.title} description={event.excerpt}>
  <article>
    <header class="bg-gradient-to-br from-dark via-dark-light to-primary-900 py-20 sm:py-28">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <a
          href="/arrangement"
          class="inline-flex items-center gap-1 text-sm text-gray-400 transition-colors hover:text-white"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Tilbake til arrangement
        </a>
        {formattedDate && (
          <time datetime={event.date} class="mt-6 block text-sm font-medium text-primary-400 uppercase tracking-wide">
            {formattedDate}
          </time>
        )}
        <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {event.title}
        </h1>
        {event.location && (
          <div class="mt-4 flex items-center gap-2 text-gray-300">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {event.location}
          </div>
        )}
      </div>
    </header>

    {event.image && (
      <div class="mx-auto -mt-8 max-w-4xl px-4 sm:px-6 lg:px-8">
        <img
          src={event.image}
          alt={event.title}
          class="w-full rounded-2xl shadow-xl"
          loading="eager"
        />
      </div>
    )}

    <div class="py-12 sm:py-16">
      <div class="prose prose-lg mx-auto max-w-4xl px-4 sm:px-6 lg:px-8" set:html={event.content} />
    </div>
  </article>
</Layout>
